<UserControl x:Class="VTuberKitForYMM4.Commons.CustomPropertyEditor.CustomComboBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" 
             d:DesignWidth="300" Name="this">

    <Grid Height="26">
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition Width="26"/>
        </Grid.ColumnDefinitions>
        <ComboBox Grid.Column="0"
           x:Name="PART_ComboBox"
           ItemsSource="{Binding ElementName=this, Path=CustomViewModel.ItemsSource}"
           DisplayMemberPath="DisplayMember"
           SelectedValue="{Binding ElementName=this, Path=CustomViewModel.SelectedValue}"
           SelectionChanged="ComboBox_SelectionChanged"
           IsEnabled="{Binding ElementName=this, Path=CustomViewModel.IsEnabled}">
        </ComboBox>
        <Button Grid.Column="1"
           x:Name="PART_ReloadButton"
           Click="ReloadButton_Click"
           IsEnabled="{Binding ElementName=this, Path=CustomViewModel.IsEnabled}">
            ↻
        </Button>
    </Grid>
</UserControl>
