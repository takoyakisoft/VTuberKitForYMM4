<UserControl x:Class="VTuberKitForYMM4.Commons.CustomPropertyEditor.DynamicFaceOverridesEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:YukkuriMovieMaker.Controls;assembly=YukkuriMovieMaker.Plugin"
             mc:Ignorable="d"
             x:Name="this"
             d:DesignWidth="640"
             MinWidth="360">
    <UserControl.Resources>
        <Style x:Key="AnimationSliderHoldCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Width" Value="26" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </UserControl.Resources>
    <Grid MinWidth="360">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,6" MinWidth="360">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0"
                     Margin="0,0,6,0"
                     VerticalContentAlignment="Center"
                     Text="{Binding ElementName=this, Path=FilterText, UpdateSourceTrigger=PropertyChanged}" />
            <Button Grid.Column="1"
                    Width="26"
                    Content="↻"
                    Click="ReloadButton_Click" />
        </Grid>

        <TabControl Grid.Row="1" MinWidth="360">
            <TabItem Header="Param">
                <Expander x:Name="ParameterExpander"
                          Margin="0,0,0,6"
                          IsExpanded="False"
                          Expanded="ParameterExpander_Expanded"
                          Collapsed="ParameterExpander_Collapsed">
                    <Expander.Header>
                        <TextBlock Text="Param一覧" />
                    </Expander.Header>
                    <ListBox x:Name="ParameterList"
                             Margin="0,4,0,0"
                             MaxHeight="720"
                             Background="Transparent"
                             BorderThickness="0"
                             ScrollViewer.CanContentScroll="True"
                             VirtualizingPanel.IsVirtualizing="True"
                             VirtualizingPanel.VirtualizationMode="Recycling">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,6"
                                        Padding="2,2,0,2"
                                        Background="Transparent">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="26" />
                                            <ColumnDefinition Width="26" />
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Row="0"
                                                Grid.Column="0"
                                                Grid.ColumnSpan="3"
                                                Margin="0,0,0,6"
                                                Background="Transparent"
                                                Cursor="SizeWE"
                                                MouseLeftButtonDown="ParameterLabel_MouseLeftButtonDown"
                                                MouseMove="ParameterLabel_MouseMove"
                                                MouseLeftButtonUp="ParameterLabel_MouseLeftButtonUp">
                                            <TextBlock FontWeight="Bold"
                                                       Text="{Binding DisplayName}" />
                                        </Border>
                                        <controls:AnimationSlider Grid.Row="1"
                                                                  Grid.Column="0"
                                                                  Margin="0,0,6,0"
                                                                  Animation="{Binding Value, Mode=OneWay}"
                                                                  Unit=""
                                                                  StringFormat="F3"
                                                                  DefaultValue="{Binding DefaultValue}"
                                                                  DefaultMin="{Binding Min}"
                                                                  DefaultMax="{Binding Max}"
                                                                  Loaded="DetailAnimationSlider_Loaded"
                                                                  DataContextChanged="DetailAnimationSlider_DataContextChanged" />
                                        <CheckBox Grid.Row="1"
                                                  Grid.Column="1"
                                                  Style="{StaticResource AnimationSliderHoldCheckBoxStyle}"
                                                  IsChecked="{Binding Hold, Mode=TwoWay}"
                                                  Checked="CheckBox_Changed"
                                                  Unchecked="CheckBox_Changed" />
                                        <Button Grid.Row="1"
                                                Grid.Column="2"
                                                Width="26"
                                                Content="↻"
                                                Click="ActionButton_Click"
                                                Command="{Binding ResetCommand}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Expander>
            </TabItem>
            <TabItem Header="Part">
                <Expander x:Name="PartExpander"
                          Margin="0,0,0,6"
                          IsExpanded="False"
                          Expanded="PartExpander_Expanded"
                          Collapsed="PartExpander_Collapsed">
                    <Expander.Header>
                        <TextBlock Text="Part一覧" />
                    </Expander.Header>
                    <ListBox x:Name="PartList"
                             Margin="0,4,0,0"
                             MaxHeight="720"
                             Background="Transparent"
                             BorderThickness="0"
                             ScrollViewer.CanContentScroll="True"
                             VirtualizingPanel.IsVirtualizing="True"
                             VirtualizingPanel.VirtualizationMode="Recycling">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,6"
                                        Padding="2,2,0,2"
                                        Background="Transparent">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="26" />
                                            <ColumnDefinition Width="26" />
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Row="0"
                                                Grid.Column="0"
                                                Grid.ColumnSpan="3"
                                                Margin="0,0,0,6"
                                                Background="Transparent"
                                                Cursor="SizeWE"
                                                MouseLeftButtonDown="PartLabel_MouseLeftButtonDown"
                                                MouseMove="PartLabel_MouseMove"
                                                MouseLeftButtonUp="PartLabel_MouseLeftButtonUp">
                                            <TextBlock FontWeight="Bold"
                                                       Text="{Binding DisplayName}" />
                                        </Border>
                                        <controls:AnimationSlider Grid.Row="1"
                                                                  Grid.Column="0"
                                                                  Margin="0,0,6,0"
                                                                  Animation="{Binding Opacity, Mode=OneWay}"
                                                                  Unit=""
                                                                  StringFormat="F3"
                                                                  DefaultValue="1"
                                                                  DefaultMin="0"
                                                                  DefaultMax="1"
                                                                  Loaded="DetailAnimationSlider_Loaded"
                                                                  DataContextChanged="DetailAnimationSlider_DataContextChanged" />
                                        <CheckBox Grid.Row="1"
                                                  Grid.Column="1"
                                                  Style="{StaticResource AnimationSliderHoldCheckBoxStyle}"
                                                  IsChecked="{Binding Hold, Mode=TwoWay}"
                                                  Checked="CheckBox_Changed"
                                                  Unchecked="CheckBox_Changed" />
                                        <Button Grid.Row="1"
                                                Grid.Column="2"
                                                Width="26"
                                                Content="↻"
                                                Click="ActionButton_Click"
                                                Command="{Binding ResetCommand}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Expander>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
